# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000

# ─── Database ─────────────────────────────────────────────────────────────────
# Use the INTERNAL URL from Render Postgres dashboard (no SSL needed on same network)
DATABASE_URL=postgresql://user:password@host/dbname

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=replace_with_64_byte_random_hex
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Your Netlify URL (no trailing slash)
FRONTEND_URL=https://your-app.netlify.app
